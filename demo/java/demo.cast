[0.002069, "o", "[\u001b[36mbuilder\u001b[0m] \u001b[34m\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[34m\u001b[1mPaketo Buildpack for Maven\u001b[0m\u001b[34m 6.22.3\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m]   \u001b[34;2;3mhttps://github.com/paketo-buildpacks/maven\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m]   \u001b[2mBuild Configuration:\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_EXCLUDE_FILES                                                                            colon separated list of glob patterns, matched source files are removed\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_INCLUDE_FILES                                                                            colon separated list of glob patterns, matched source files are included\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_JAVA_INSTALL_NODE                 false                                                  whether to install Yarn/Node binaries based on the presence of a package.json or yarn.lock file\u001b[0m\r\n"]
[0.000016, "o", "[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_MAVEN_ACTIVE_PROFILES                                                                    the active profiles (comma separated: such as: p1,!p2,?p3) to pass to Maven\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_MAVEN_ADDITIONAL_BUILD_ARGUMENTS                                                         the additionnal arguments (appended to BP_MAVEN_BUILD_ARGUMENTS) to pass to Maven\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_MAVEN_BUILD_ARGUMENTS             -Dmaven.test.skip=true --no-transfer-progress package  the arguments to pass to Maven\u001b[0m\r\n"]
[0.000006, "o", "[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_MAVEN_BUILT_ARTIFACT              target/*.[ejw]ar                                       the built application artifact explicitly.  Supersedes $BP_MAVEN_BUILT_MODULE\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_MAVEN_BUILT_MODULE                                                                       the module to find application artifact in\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_MAVEN_DAEMON_ENABLED              false                                                  use maven daemon\u001b[0m\r\n"]
[0.000024, "o", "[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_MAVEN_POM_FILE                    pom.xml                                                the location of the main pom.xml file, relative to the application root\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_MAVEN_SETTINGS_PATH                                                                      the path to a Maven settings file\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_MAVEN_VERSION                     3                                                      the Maven version\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_NODE_PROJECT_PATH                                                                        configure a project subdirectory to look for `package.json` and `yarn.lock` files\u001b[0m\r\n"]
[0.092535, "o", "[\u001b[36mbuilder\u001b[0m]   \u001b[34mApache Maven 3.9.14\u001b[0m: \u001b[33mContributing\u001b[0m to layer\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    \u001b[33mDownloading\u001b[0m\u001b[2m from https://repo1.maven.org/maven2/org/apache/maven/apache-maven/3.9.14/apache-maven-3.9.14-bin.tar.gz\u001b[0m\r\n"]
