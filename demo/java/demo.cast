[0.003524, "o", "[\u001b[36mbuilder\u001b[0m] \u001b[34m\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[34m\u001b[1mPaketo Buildpack for BellSoft Liberica\u001b[0m\u001b[34m 11.6.1\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m]   \u001b[34;2;3mhttps://github.com/paketo-buildpacks/bellsoft-liberica\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m]   \u001b[2mBuild Configuration:\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_JVM_JLINK_ARGS           --no-man-pages --no-header-files --strip-debug --compress=1  configure custom link arguments (--output must be omitted)\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_JVM_JLINK_ENABLED        false                                                        enables running jlink tool to generate custom JRE\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_JVM_TYPE                 JRE                                                          the JVM type - JDK or JRE\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BP_JVM_VERSION              21                                                           the Java version\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m]   \u001b[2mLaunch Configuration:\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_DEBUG_ENABLED           false                                                        enables Java remote debugging support\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_DEBUG_PORT              8000                                                         configure the remote debugging port\u001b[0m\r\n"]
[0.000022, "o", "[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_DEBUG_SUSPEND           false                                                        configure whether to suspend execution until a debugger has attached\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_HEAP_DUMP_PATH                                                                       write heap dumps on error to this path\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_JAVA_NMT_ENABLED        true                                                         enables Java Native Memory Tracking (NMT)\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_JAVA_NMT_LEVEL          summary                                                      configure level of NMT, summary or detail\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_JFR_ARGS                                                                             configure custom Java Flight Recording (JFR) arguments\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_JFR_ENABLED             false                                                        enables Java Flight Recording (JFR)\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_JMX_ENABLED             false                                                        enables Java Management Extensions (JMX)\u001b[0m\r\n"]
[0.000012, "o", "[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_JMX_PORT                5000                                                         configure the JMX port\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_JVM_HEAD_ROOM           0                                                            the headroom in memory calculation\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_JVM_LOADED_CLASS_COUNT  35% of classes                                               the number of loaded classes in memory calculation\u001b[0m\r\n"]
[0.000008, "o", "[\u001b[36mbuilder\u001b[0m] \u001b[2m    $BPL_JVM_THREAD_COUNT        250                                                          the number of threads in memory calculation\u001b[0m\r\n[\u001b[36mbuilder\u001b[0m] \u001b[2m    $JAVA_TOOL_OPTIONS                                                                        the JVM launch flags\u001b[0m\r\n"]
